<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Hero banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_diagnose_hero"
        android:paddingHorizontal="22dp"
        android:paddingTop="28dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/diagTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/diag_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/diagSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_sub"
            android:textSize="13sp"
            android:textColor="@color/white_85"
            android:lineSpacingMultiplier="1.5"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Crop picker -->
            <TextView
                android:id="@+id/selectCropLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_crop"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/cropOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:nestedScrollingEnabled="false"/>

            <!-- Upload area -->
            <LinearLayout
                android:id="@+id/uploadArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="18dp"
                android:layout_marginBottom="18dp"
                android:padding="32dp"
                android:background="@drawable/bg_dashed_upload"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📸"
                    android:textSize="40sp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/uploadLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_label"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/uploadSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_sub"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="4dp"/>

                <ImageView
                    android:id="@+id/previewImg"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Analyze button -->
            <TextView
                android:id="@+id/analyzeBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginBottom="20dp"
                android:padding="15dp"
                android:gravity="center"
                android:text="@string/analyze_btn"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_analyze_btn"
                android:enabled="false"
                android:clickable="true"
                android:focusable="true"/>

            <!-- AI result card -->
            <LinearLayout
                android:id="@+id/aiResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="18dp"
                android:layout_marginBottom="18dp"
                android:padding="16dp"
                android:paddingStart="20dp"
                android:background="@drawable/bg_ai_result"
                android:visibility="gone">

                <TextView
                    android:id="@+id/aiResultTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_result_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/aiResultText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.6"/>
            </LinearLayout>

            <!-- ── Diagnosis History Section ───────────────────── -->
            <LinearLayout
                android:id="@+id/historySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/history_title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/historyRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="18dp"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
