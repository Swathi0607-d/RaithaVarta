<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/green_dark"
        android:paddingHorizontal="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/allTipsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/all_tips"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <TextView
            android:id="@+id/filterByCrop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter_by_crop"
            android:textSize="12sp"
            android:textColor="@color/white_70"
            android:layout_marginTop="3dp"/>

        <!-- All Tips / Saved Tips toggle tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:padding="3dp"
            android:background="@drawable/bg_lang_toggle">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="📋 All Tips"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_lang_active"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tabSaved"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="💾 Saved"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_lang_inactive"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Crop filter pills (shown in All Tips tab) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tipsFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:overScrollMode="never"/>
    </LinearLayout>

    <!-- Empty state for Saved tab -->
    <TextView
        android:id="@+id/emptyLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💾 No saved tips yet.\nSwipe right on a flash card to save it!"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:padding="32dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tipsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"/>

</LinearLayout>
