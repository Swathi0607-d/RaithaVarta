<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.RaithaVarta" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_mid</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber</item>
        <item name="colorSecondaryVariant">@color/amber</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/page_bg</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.RaithaVarta.Dialog</item>
    </style>

    <style name="Theme.RaithaVarta.Splash" parent="Theme.RaithaVarta">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:statusBarColor">@color/green_dark</item>
    </style>

    <style name="ThemeOverlay.RaithaVarta.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/green_mid</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Dialog.Title</item>
    </style>

    <style name="Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/green_dark</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/green_mid</item>
    </style>
    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>
</resources>
