<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="28dp">

            <!-- Logo area -->
            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name_kn"
                android:textSize="15sp"
                android:textColor="@color/white_85"
                android:layout_marginBottom="28dp"/>

            <!-- Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Title inside card -->
                    <TextView
                        android:id="@+id/loginTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_title_signin"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/loginSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_sub_signin"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginBottom="20dp"/>

                    <!-- Sign-up only fields -->
                    <EditText
                        android:id="@+id/fieldSignupName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/setup_name_hint"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_card_white"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <EditText
                        android:id="@+id/fieldSignupDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/setup_district_hint"
                        android:inputType="text"
                        android:background="@drawable/bg_card_white"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <EditText
                        android:id="@+id/fieldSignupCrops"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/setup_crops_hint"
                        android:inputType="text"
                        android:background="@drawable/bg_card_white"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <!-- PIN field (always visible) -->
                    <EditText
                        android:id="@+id/fieldPin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/login_pin_hint"
                        android:inputType="numberPassword"
                        android:background="@drawable/bg_card_white"
                        android:padding="14dp"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp"
                        android:maxLength="6"/>

                    <!-- Primary button -->
                    <TextView
                        android:id="@+id/btnPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/login_btn_signin"
                        android:textColor="@color/green_dark"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="14dp"
                        android:background="@drawable/bg_splash_btn"
                        android:elevation="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:layout_marginBottom="16dp"/>

                    <!-- Switch mode link -->
                    <TextView
                        android:id="@+id/btnSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/login_btn_to_signup"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_sub"
                android:textSize="11sp"
                android:textColor="@color/white_70"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginTop="24dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
