<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/green_dark"
        android:paddingTop="14dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/topbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌾 Raitha-Varta"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/topbarDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_tips"
                    android:textSize="11sp"
                    android:textColor="@color/white_70"/>
            </LinearLayout>

            <TextView
                android:id="@+id/weatherBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weather"
                android:textSize="12sp"
                android:textColor="@color/white_85"
                android:background="@drawable/bg_weather_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/catsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/catsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="18dp"/>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Flash Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="20dp">

                <TextView
                    android:id="@+id/flashLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flash_label"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"
                    android:drawableStart="@drawable/leading_dash"
                    android:drawablePadding="6dp"/>

                <FrameLayout
                    android:id="@+id/cardStack"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <LinearLayout
                    android:id="@+id/cardDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/swipeSkip"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swipe_skip"
                        android:textSize="13sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"
                        android:padding="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>

                    <TextView
                        android:id="@+id/swipeCards"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swipe_cards"
                        android:textSize="11sp"
                        android:textColor="@color/text_muted"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/swipeSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/swipe_save"
                        android:textSize="13sp"
                        android:textColor="@color/green_dark"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:padding="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Success Stories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/successTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/success_title"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/seeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textSize="12sp"
                        android:textColor="@color/green_mid"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/storiesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Expert Ask -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="18dp"
                android:padding="20dp"
                android:background="@drawable/bg_expert">

                <TextView
                    android:id="@+id/expertTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/expert_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/expertSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/expert_sub"
                    android:textSize="12sp"
                    android:textColor="@color/white_70"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/uploadLeafBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload_leaf_btn"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_dark"
                    android:background="@drawable/bg_expert_btn"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="10dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
