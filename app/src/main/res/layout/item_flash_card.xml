<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="280dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/fcBg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="55">

            <TextView
                android:id="@+id/fcEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="72sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_card_overlay_fade"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="45"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@color/card_bg">

            <TextView
                android:id="@+id/fcCrop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/green_mid"
                android:textAllCaps="true"
                android:letterSpacing="0.08"/>

            <TextView
                android:id="@+id/fcAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/green_dark"
                android:lineSpacingMultiplier="1.35"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/fcDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="4dp"
                android:maxLines="3"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/fcTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/green_mid"
                android:background="@drawable/bg_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
